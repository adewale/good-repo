    {
      "id": "round3-fixture-private-spike",
      "split": "tune",
      "kind": "repo-audit",
      "files": [
        "fixtures/round3-private-spike/README.md",
        "fixtures/round3-private-spike/package.json"
      ],
      "prompt": "Audit the attached tiny private repo. Should it add public-launch surface before continuing?",
      "expected_behavior": [
        "Classify as private scratchpad/spike.",
        "Avoid badges/changelog/semantic-release/contribution-guide cargo cult; recommend right-sized next check."
      ],
      "assertions": [
        {
          "name": "right-sized-next-step",
          "type": "contains_any",
          "values": [
            "right-sized",
            "proportional",
            "smallest",
            "not necessary"
          ]
        },
        {
          "name": "no-public-launch-musts",
          "type": "not_regex",
          "pattern": "(?i)(semantic-release|changelog|contribution guide|badges).{0,80}(must|required|needed)"
        },
        {
          "name": "fixture-script-oracle",
          "type": "script",
          "command": [
            "python3",
            "oracles/fixture_oracle.py",
            "{output_dir}",
            "round3-fixture-private-spike"
          ],
          "pass_exit_code": 0,
          "timeout_s": 10,
          "description": "Deterministic fixture-backed oracle; run benchmark with --allow-scripts."

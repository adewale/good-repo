    {
      "id": "neg-internal-spike-no-public-launch-checklist",
      "split": "tune",
      "kind": "repo-audit",
      "prompt": "Audit this repo: private two-file spike, no users, no releases, no package publishing, and README says “scratchpad for trying a parser idea.” Should it add badges, CI matrix, changelog, semantic-release, and contribution guide before continuing?",
      "expected_behavior": [
        "Classify as tiny/private spike.",
        "Avoid public launch checklist; recommend only right-sized next steps."
      ],
      "assertions": [
        {
          "name": "classifies-spike",
          "type": "contains_any",
          "values": [
            "spike",
            "scratchpad",
            "private",
            "experiment"
          ]
        },
        {
          "name": "right-sized",
          "type": "contains_any",
          "values": [
            "right-sized",
            "proportional",
            "not necessary",
            "overkill"
          ]
        },
        {
          "name": "avoids-launch-checklist",
          "type": "not_regex",
          "pattern": "(?i)(semantic-release|changelog|contribution guide|CI matrix).{0,80}(must|required|needed)"
        },
        {
          "name": "round-2-qualitative-review",
          "type": "judge",
          "rubric": [

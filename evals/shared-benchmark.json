    {
      "id": "neg-tiny-personal-experiment",
      "split": "tune",
      "kind": "adversarial",
      "prompt": "A tiny personal experiment repo has a short README, no issues traffic, no external contributors, and no sensitive code. Audit it. Should it add CODE_OF_CONDUCT, SECURITY.md, issue forms, Dependabot, branch protection, and a large CI suite?",
      "expected_behavior": [
        "Keep recommendations proportionate/right-sized for a tiny personal experiment.",
        "Recommend lightweight basics and explicitly defer governance/CI artifacts unless contributor, security, package, release, or maintainer-capacity conditions exist."
      ],
      "assertions": [
        {
          "name": "right-sized-experiment",
          "type": "contains_any",
          "values": [
            "proportionate",
            "right-sized",
            "right-size",
            "governance theater",
            "overkill",
            "template-zombie",
            "proportional",
            "proportional to scope"
          ]
        },
        {
          "name": "defer-heavy-governance",
          "type": "regex",
          "pattern": "\\b(defer|skip|avoid|not necessary|overkill|do not|don't)\\b[\\s\\S]{0,220}\\b(CODE_OF_CONDUCT|code of conduct|SECURITY\\.md|security policy|issue forms?|Dependabot|branch protection|large CI|CI suite)\\b|\\b(CODE_OF_CONDUCT|code of conduct|SECURITY\\.md|security policy|issue forms?|Dependabot|branch protection|large CI|CI suite)\\b[\\s\\S]{0,220}\\b(defer|skip|avoid|not necessary|overkill|do not|don't)\\b",
          "description": "Must explicitly reject or defer at least one heavy governance/automation artifact."
        },
        {
          "name": "lightweight-basics",
          "type": "contains_any",
          "values": [
            "README",
            "status",
            "run command",
            "expected result",
            "smoke check",
            "license decision"
          ]
        },
        {
          "name": "qualitative-review",
          "type": "judge",
          "rubric": [
            "Proportionality",
            "False-positive restraint",
            "Names lightweight basics",
            "Defers heavy governance unless clear conditions apply"
          ]
        }
      ],
      "tags": [],
      "domain": "repository-quality",
      "difficulty": "extended",
      "success_goals": [
        "outcome",
        "style"
      ]
    },
